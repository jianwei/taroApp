.profile-page{padding:24rpx}.profile-page .user-card{background:-webkit-linear-gradient(315deg,#667eea,#764ba2);background:linear-gradient(135deg,#667eea,#764ba2);border-radius:16rpx;color:#fff;margin-bottom:24rpx;padding:48rpx 32rpx;text-align:center}.profile-page .user-card .avatar{-webkit-align-items:center;background:hsla(0,0%,100%,.2);border-radius:50%;display:-webkit-flex;display:-ms-flexbox;display:flex;height:120rpx;margin:0 auto 24rpx;width:120rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;font-size:48rpx;justify-content:center}.profile-page .user-card .nickname{font-size:36rpx;font-weight:700;margin-bottom:8rpx}.profile-page .user-card .phone{font-size:28rpx;opacity:.8}.profile-page .menu-list{background:#fff;border-radius:16rpx;overflow:hidden}.profile-page .version{color:#999;font-size:24rpx;margin-top:48rpx;text-align:center}